{
  "mqtt": {
    "demo-mqtt": {
      "config": {
        "id": "demo-mqtt",
        "name": "Demo Mosquitto",
        "host": "mqtt",
        "port": 1883,
        "protocol": "mqtt",
        "autoSubscribe": true,
        "reconnect": true,
        "reconnectPeriod": 5000
      }
    },
    "demo-mqtt2": {
      "config": {
        "id": "demo-mqtt2",
        "name": "North Plant (mqtt2)",
        "host": "mqtt2",
        "port": 1883,
        "protocol": "mqtt",
        "autoSubscribe": true,
        "reconnect": true,
        "reconnectPeriod": 5000
      }
    },
    "demo-mqtt3": {
      "config": {
        "id": "demo-mqtt3",
        "name": "South Plant (mqtt3)",
        "host": "mqtt3",
        "port": 1883,
        "protocol": "mqtt",
        "autoSubscribe": true,
        "reconnect": true,
        "reconnectPeriod": 5000
      }
    }
  },
  "opcua": {
    "demo-opcua": {
      "id": "demo-opcua",
      "name": "Demo OPC-PLC",
      "endpointUrl": "opc.tcp://opcua:50000",
      "securityMode": "None",
      "securityPolicy": "None"
    }
  },
  "cesmii": null,
  "i3x": null,
  "recordings": {
    "demo-historian": {
      "id": "demo-historian",
      "name": "Built-in historian",
      "brokerId": "demo-mqtt",
      "filter": "factory/#",
      "target": { "type": "file" },
      "enabled": true
    }
  }
}
